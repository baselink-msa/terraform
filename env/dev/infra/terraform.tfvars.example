aws_region   = "ap-northeast-2"
project_name = "baselink"
environment  = "dev"

vpc_cidr                  = "10.0.0.0/16"
availability_zones        = ["ap-northeast-2a", "ap-northeast-2c"]
public_subnet_cidrs       = ["10.0.0.0/24", "10.0.10.0/24"]
private_app_subnet_cidrs  = ["10.0.20.0/24", "10.0.30.0/24"]
private_data_subnet_cidrs = ["10.0.40.0/24", "10.0.50.0/24"]

enable_nat_gateway = true
single_nat_gateway = true

# Set this after the EKS cluster name is agreed.
eks_cluster_name = ""
